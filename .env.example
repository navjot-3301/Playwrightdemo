# ─────────────────────────────────────────────
# Gmail Login - Playwright Test Environment Variables
# ─────────────────────────────────────────────
# Copy this file, rename to .env and fill in real values
# This file is safe to commit — .env is NOT

# Gmail Credentials
VALID_EMAIL=your_email@gmail.com
VALID_PASSWORD=your_password

# Negative Test Credentials
INVALID_EMAIL=userexample.com
NON_EXIST_EMAIL=nonexistent12345xyz@gmail.com
WRONG_PASSWORD=WrongPassword@999

# 2FA Credentials (TC-013, TC-014)
SMS_OTP=123456
TOTP_CODE=654321

# Auth State Path (TC-017 - Remember This Device)
AUTH_STATE_PATH=auth/storageState.json

# Playwright Settings
HEADLESS=true
BASE_URL=https://gmail.com
